{
  "name": "foundryvtt-mediasoup-webrtc",
  "version": "0.7.20",
  "description": "WebRTC audio/video communication module for FoundryVTT using MediaSoup SFU server",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:server": "cd server && cargo test",
    "check": "bun run typecheck && bun run build && bun run lint && bun run test"
  },
  "keywords": [
    "foundryvtt",
    "foundry-vtt",
    "module",
    "webrtc",
    "mediasoup",
    "audio",
    "video",
    "communication",
    "tabletop",
    "rpg"
  ],
  "author": "Lauri Gates",
  "license": "MIT",
  "dependencies": {
    "mediasoup-client": "^3.12.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.54.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.2.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laurigates/foundryvtt-mediasoup-webrtc.git"
  },
  "bugs": {
    "url": "https://github.com/laurigates/foundryvtt-mediasoup-webrtc/issues"
  },
  "homepage": "https://github.com/laurigates/foundryvtt-mediasoup-webrtc#readme"
}

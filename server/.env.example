# MediaSoup Server Configuration

# Server listen address for WebSocket connections
MEDIASOUP_LISTEN_ADDR=0.0.0.0:3000

# Optional HTTP server for static files
# MEDIASOUP_HTTP_ADDR=0.0.0.0:8080

# Number of MediaSoup worker processes
MEDIASOUP_NUM_WORKERS=1

# MediaSoup worker log level (debug, warn, error)
MEDIASOUP_LOG_LEVEL=warn

# MediaSoup worker log tags (comma-separated)
MEDIASOUP_LOG_TAGS=info,ice,dtls,rtp,rtcp

# RTC port range for UDP/TCP
MEDIASOUP_RTC_MIN_PORT=10000
MEDIASOUP_RTC_MAX_PORT=10100

# Announced IP (if different from listen IP, for NAT/Docker)
# MEDIASOUP_ANNOUNCED_IP=192.168.1.100

# Shared secret clients must present to connect (see #118). When unset the
# server runs UNAUTHENTICATED (development only) and logs a warning. Set the
# same value in the FoundryVTT module settings.
# MEDIASOUP_AUTH_TOKEN=change-me

# Optional native TLS termination (wss://). Point these at PEM files to let the
# server terminate TLS itself instead of relying on a reverse proxy. Both must
# be set together.
# MEDIASOUP_TLS_CERT=/path/to/fullchain.pem
# MEDIASOUP_TLS_KEY=/path/to/privkey.pem